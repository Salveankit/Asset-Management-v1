DEBUG=False
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=
PRODUCT_NAME=Asset Platform
PRODUCT_SHORT_NAME=AssetOps
COMPANY_NAME=Organisation Workspace
PRODUCT_LOGO=
# Set DATABASE_URL for Neon/PostgreSQL in production. Leave it unset only for local SQLite development.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# AI intake automatically prefers Gemini when GEMINI_API_KEY is configured.
AI_INTAKE_PROVIDER=auto
# Set these only if you want to use Azure OpenAI instead.
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_TIMEOUT_SECONDS=30
# AZURE_OPENAI_MAX_RETRIES=3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30
